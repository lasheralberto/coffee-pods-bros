rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/appConfig/global).data.adminUserId == request.auth.uid;
    }

    function adminUid() {
      return get(/databases/$(database)/documents/appConfig/global).data.adminUserId;
    }

    /* Public catalog */
    match /productsCatalog/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /suscriptionPlans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    /* App config */
    match /appConfig/global {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    /* User-scoped documents */
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    match /usersToQuiz/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /quizToSuscription/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /userPacks/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /usersToSuscription/{uid} {
      allow read, write: if isOwner(uid);
    }

    /* Purchase history */
    match /userPurchasesPacks/{purchaseId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if (signedIn() && resource.data.uid == request.auth.uid) || isAdmin();
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    /* Chat: one thread per user */
    match /chats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if (isOwner(userId) || isAdmin())
        && request.resource.data.userId == userId;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if signedIn()
          && (
            (
              isOwner(userId)
              && request.resource.data.senderId == request.auth.uid
              && request.resource.data.recipientId == adminUid()
            )
            ||
            (
              isAdmin()
              && request.resource.data.senderId == request.auth.uid
              && request.resource.data.recipientId == userId
            )
          )
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false;
      }
    }

    /* Deny everything else */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}