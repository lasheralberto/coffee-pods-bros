rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && get(/databases/$(database)/documents/appConfig/global).data.adminUserId == request.auth.uid;
    }

    /* Public catalog */
    match /productsCatalog/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /suscriptionPlans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    /* App config */
    match /appConfig/global {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    /* User-scoped documents */
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid);
    }

    match /usersToQuiz/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /quizToSuscription/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /userPacks/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /usersToSuscription/{uid} {
      allow read, write: if isOwner(uid);
    }

    /* Purchase history */
    match /userPurchasesPacks/{purchaseId} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    /* Chat: one thread per user */
    match /chats/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /messages/{messageId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /* Deny everything else */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
